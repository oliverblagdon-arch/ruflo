# TradeFlow AI — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+441234567890

# SMTP (for lead follow-up emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password

# Development
# Set to true to log instead of sending real SMS/emails during testing
DRY_RUN=true
