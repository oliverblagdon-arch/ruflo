# =============================================================================
# AI Video Pipeline — configuration
# Copy to `.env` and fill in. NEVER commit your real .env (see .gitignore).
# Every stage is swappable: change the *_PROVIDER var to switch tools.
# =============================================================================

# ----- Stage selection (the "swap any tool" knobs) ---------------------------
SCRIPT_PROVIDER=openai          # openai | anthropic
TTS_PROVIDER=openai             # openai | elevenlabs
VISUALS_PROVIDER=pexels         # pexels
CAPTIONS_PROVIDER=whisper       # whisper (OpenAI)
ASSEMBLY_PROVIDER=ffmpeg        # ffmpeg

# Which platforms to publish to (comma separated): youtube,instagram,tiktok
PUBLISH_TARGETS=youtube,instagram,tiktok

# YouTube orientation: vertical (Shorts) | horizontal (long-form)
YT_ORIENTATION=vertical

# ----- Script (LLM) ----------------------------------------------------------
OPENAI_API_KEY=
OPENAI_SCRIPT_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_SCRIPT_MODEL=claude-sonnet-4-6

# ----- Voiceover (TTS) -------------------------------------------------------
# OpenAI TTS reuses OPENAI_API_KEY
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# ElevenLabs (premium, usage-based — watch the bill at scale)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ----- Visuals (stock footage, Lane A) ---------------------------------------
PEXELS_API_KEY=
# How many stock clips to stitch per video
VISUALS_CLIP_COUNT=6

# ----- Captions (Whisper) reuses OPENAI_API_KEY ------------------------------
WHISPER_MODEL=whisper-1

# ----- Publishing: YouTube (Data API v3, OAuth2) -----------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback
YOUTUBE_REFRESH_TOKEN=

# ----- Publishing: Instagram Reels (Graph API) -------------------------------
# Requires an IG Business/Creator account linked to a Facebook Page.
# Graph API pulls the video from a PUBLIC url — you must host output/ somewhere
# reachable (CDN, S3, static server). PUBLIC_BASE_URL + filename = video_url.
IG_USER_ID=
IG_ACCESS_TOKEN=
PUBLIC_BASE_URL=

# ----- Publishing: TikTok (Content Posting API) ------------------------------
# UNAUDITED apps can only push to drafts/inbox (manual publish in-app).
# Public direct-post requires passing TikTok's audit. See README.
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY  # SELF_ONLY (draft-safe) | PUBLIC_TO_EVERYONE (audited only)
