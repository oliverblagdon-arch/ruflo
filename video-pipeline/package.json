{
  "name": "ai-video-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modular, self-host AI video production + publishing pipeline (YouTube / TikTok / Instagram Reels)",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "video-pipeline": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "produce": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
